{
  "name": "proposal-studio",
  "version": "1.0.0",
  "description": "Dynamic Gantt chart generator",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "build:css": "tailwindcss -i ./Public/styles/tailwind-source.css -o ./Public/styles/tailwind.css --minify",
    "build:js": "node scripts/build-js.mjs",
    "build": "npm run build:css && npm run build:js",
    "dev:css": "tailwindcss -i ./Public/styles/tailwind-source.css -o ./Public/styles/tailwind.css --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --watch",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest tests/server tests/public",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest tests/integration",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest --coverage --ci --forceExit",
    "lint": "eslint 'Public/**/*.js' 'server/**/*.js' 'server.js' --ignore-pattern 'Public/dist/**'",
    "lint:fix": "eslint 'Public/**/*.js' 'server/**/*.js' 'server.js' --fix --ignore-pattern 'Public/dist/**'",
    "analyze:deps": "npx depcheck",
    "analyze:dead-code": "npx knip",
    "analyze:deps-graph": "npx madge Public/main.js --image reports/main-deps.svg && npx madge Public/viewer.js --image reports/viewer-deps.svg && npx madge server.js --image reports/server-deps.svg",
    "analyze:all": "npm run lint && npm run analyze:deps && npm run analyze:dead-code"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.0.0",
    "jsonrepair": "^3.13.1",
    "mammoth": "^1.7.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@jest/globals": "^30.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^30.2.0",
    "postcss": "^8.5.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17"
  }
}
